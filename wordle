# ---------- puzzle data ----------

def fetch_word(d):
    DATA_DIR.mkdir(exist_ok=True)
    cache = {}
    if CACHE_FILE.exists():
        try:
            cache = json.loads(CACHE_FILE.read_text())
        except json.JSONDecodeError:
            cache = {}
    key = d.isoformat()
    if key in cache:
        return cache[key]
    url = f'https://www.nytimes.com/svc/wordle/v2/{key}.json'
    req = urllib.request.Request(url, headers={'User-Agent': UA})
    with urllib.request.urlopen(req, timeout=10) as r:
        data = json.loads(r.read())
    cache[key] = data
    CACHE_FILE.write_text(json.dumps(cache))
    return data


# Wordle #0 — Cade Crane's first NYT-archived puzzle (CIGAR, 2021-06-19).
# Each subsequent puzzle adds one calendar day; the API returns
# `days_since_launch` so we can verify a number maps to the date we expected.
WORDLE_EPOCH = date(2021, 6, 19)


def fetch_word_by_number(num):
    """Fetch a historical Wordle by its puzzle number (days_since_launch)."""
    if num < 0:
        raise ValueError(f'Wordle #{num} is before #0.')
    target = WORDLE_EPOCH + timedelta(days=num)
    if target > date.today():
        raise ValueError(
            f"Wordle #{num} hasn't been published yet "
            f'(it would be {target.isoformat()}).'
        )
    data = fetch_word(target)
    actual = data.get('days_since_launch')
    if isinstance(actual, int) and actual != num:
        # Epoch drift would be obvious — surface it instead of silently lying.
        raise RuntimeError(
            f'Archive lookup mismatch: asked for #{num}, '
            f'NYT returned #{actual} for {target.isoformat()}.'
        )
    return data


# ---------- scoring + rendering ----------

def score(guess, solution):
    result = ['b'] * 5
    sol = list(solution)
    for i in range(5):
        if guess[i] == sol[i]:
            result[i] = 'g'
            sol[i] = None
    for i in range(5):
        if result[i] == 'g':
            continue
        if guess[i] in sol:
            result[i] = 'y'
            sol[sol.index(guess[i])] = None
    return result


def visible_len(s):
    return len(ANSI_RE.sub('', s))


def term_size():
    s = shutil.get_terminal_size((80, 24))
    return s.columns, s.lines


def enter_fullscreen():
    sys.stdout.write(ENTER_ALT + CLEAR + HIDE_CURSOR)
    sys.stdout.flush()


def exit_fullscreen():
    sys.stdout.write(AUTOWRAP_ON + SHOW_CURSOR + EXIT_ALT)
    sys.stdout.flush()


class RawTerminal:
    """Put stdin into raw (unbuffered, no-echo) mode for the duration of a
    `with` block, restoring the prior tty attrs on exit even if an exception
    propagates."""

    def __enter__(self):
        self.fd = sys.stdin.fileno()
        self.old = termios.tcgetattr(self.fd)
        tty.setraw(self.fd)
        return self

    def __exit__(self, *exc):
        termios.tcsetattr(self.fd, termios.TCSADRAIN, self.old)


def read_key():
    """Read a single key event from stdin (raw mode assumed). Returns
    'enter', 'backspace', 'esc', 'ctrl-c', 'ctrl-z', or a one-character string."""
    ch = sys.stdin.read(1)
    if ch in ('\r', '\n'):
        return 'enter'
    if ch in ('\x7f', '\x08'):
        return 'backspace'
    if ch == '\x03':
        return 'ctrl-c'
    if ch == '\x1a':
        return 'ctrl-z'
    if ch == '\x1b':
        # Escape may start a CSI sequence (arrow keys etc.). Drain any
        # pending bytes that arrive within ~50 ms so we don't surface them
        # as ordinary keystrokes; if nothing follows it's a bare Esc.
        rd, _, _ = select.select([sys.stdin], [], [], 0.05)
        if rd:
            sys.stdin.read(1)
            rd2, _, _ = select.select([sys.stdin], [], [], 0.01)
            if rd2:
                sys.stdin.read(1)
            return 'unknown'
        return 'esc'
    return ch


# ---------- tile primitives ----------

def small_tile(ch, state):
    color = {'g': GREEN, 'y': YELLOW, 'b': GRAY}[state]
    return f'{color}{BOLD} {ch.upper()} {RESET}'


def small_empty_tile():
    return f'{EMPTY}[ ]{RESET}'


def small_typed_tile(ch):
    return f'{TYPED_BG}{BOLD} {ch.upper()} {RESET}'


# Kept as an alias so any external callers / share helpers still resolve.
def tile(ch, state):
    return small_tile(ch, state)


def empty_tile():
    return small_empty_tile()


def big_tile_lines(ch, state):
    color = {'g': GREEN, 'y': YELLOW, 'b': GRAY}[state]
    return [
        f'{color}     {RESET}',
        f'{color}{BOLD}  {ch.upper()}  {RESET}',
        f'{color}     {RESET}',
    ]


def big_empty_tile_lines():
    return [
        f'{EMPTY}┌───┐{RESET}',
        f'{EMPTY}│   │{RESET}',
        f'{EMPTY}└───┘{RESET}',
    ]


def big_typed_tile_lines(ch):
    return [
        f'{TYPED_BG}     {RESET}',
        f'{TYPED_BG}{BOLD}  {ch.upper()}  {RESET}',
        f'{TYPED_BG}     {RESET}',
    ]


# ---------- board / keyboard ----------

def _row_tiles(guess, result):
    """Single-line tiles for a committed row."""
    return ' '.join(small_tile(c, r) for c, r in zip(guess, result))


def _row_typed(current_guess):
    """Single-line tiles for the active row: typed letters + remaining empties."""
    parts = [small_typed_tile(ch) for ch in current_guess]
    parts += [small_empty_tile()] * (5 - len(current_guess))
    return ' '.join(parts)


def _row_empty():
    return ' '.join([small_empty_tile()] * 5)


def board_lines(guesses, results, current_guess=''):
    out = []
    active_idx = len(guesses) if len(guesses) < 6 else -1
    for i in range(6):
        if i < len(guesses):
            out.append(_row_tiles(guesses[i], results[i]))
        elif i == active_idx and current_guess:
            out.append(_row_typed(current_guess))
        else:
            out.append(_row_empty())
    return out


def _big_row(tiles_lines):
    """Combine 5 per-tile [top, mid, bot] lists into 3 board lines."""
    return [' '.join(t[r] for t in tiles_lines) for r in range(3)]


def big_board_lines(guesses, results, current_guess=''):
    out = []
    active_idx = len(guesses) if len(guesses) < 6 else -1
    for i in range(6):
        if i < len(guesses):
            tiles_lines = [big_tile_lines(c, r)
                           for c, r in zip(guesses[i], results[i])]
        elif i == active_idx and current_guess:
            tiles_lines = [big_typed_tile_lines(ch) for ch in current_guess]
            tiles_lines += [big_empty_tile_lines()] * (5 - len(current_guess))
        else:
            tiles_lines = [big_empty_tile_lines() for _ in range(5)]
        out.extend(_big_row(tiles_lines))
        if i < 5:
            out.append('')
    return out


def _kbd_state(guesses, results):
    rank = {'unknown': 0, 'b': 1, 'y': 2, 'g': 3}
    state = {}
    for g, r in zip(guesses, results):
        for ch, rr in zip(g, r):
            if rank[rr] > rank.get(state.get(ch, 'unknown'), 0):
                state[ch] = rr
    return state


def keyboard_lines(guesses, results):
    state = _kbd_state(guesses, results)
    rows = ['QWERTYUIOP', 'ASDFGHJKL', 'ZXCVBNM']
    out = []
    for idx, row in enumerate(rows):
        line = ' ' * idx
        keys = []
        for ch in row:
            s = state.get(ch.lower(), 'unknown')
            if s == 'g':
                keys.append(f'{GREEN}{BOLD} {ch} {RESET}')
            elif s == 'y':
                keys.append(f'{YELLOW}{BOLD} {ch} {RESET}')
            elif s == 'b':
                keys.append(f'{KBD_GRAY} {ch} {RESET}')
            else:
                keys.append(f'{WHITE}{BOLD} {ch} {RESET}')
        line += ' '.join(keys)
        out.append(line)
    return out


def big_keyboard_lines(guesses, results):
    state = _kbd_state(guesses, results)
    rows = ['QWERTYUIOP', 'ASDFGHJKL', 'ZXCVBNM']
    out = []
    for idx, row in enumerate(rows):
        line = ' ' * (idx * 3)
        keys = []
        for ch in row:
            s = state.get(ch.lower(), 'unknown')
            if s == 'g':
                keys.append(f'{GREEN}{BOLD}  {ch}  {RESET}')
            elif s == 'y':
                keys.append(f'{YELLOW}{BOLD}  {ch}  {RESET}')
            elif s == 'b':
                keys.append(f'{KBD_GRAY}  {ch}  {RESET}')
            else:
                keys.append(f'{WHITE}{BOLD}  {ch}  {RESET}')
        line += ' '.join(keys)
        out.append(line)
    return out


def huge_keyboard_lines(guesses, results):
    """Keyboard with 5×3 keys to match the big tile aesthetic.

    Same visible width per row as `big_keyboard_lines` (5 cols/key + gap),
    but each key spans three lines with the letter centered, so the keyboard
    visually balances against the 5×3 board tiles.
    """
    state = _kbd_state(guesses, results)
    rows = ['QWERTYUIOP', 'ASDFGHJKL', 'ZXCVBNM']
    out = []
    for idx, row in enumerate(rows):
        offset = ' ' * (idx * 3)
        top, mid, bot = [], [], []
        for ch in row:
            s = state.get(ch.lower(), 'unknown')
            if s == 'g':
                color = GREEN
            elif s == 'y':
                color = YELLOW
            elif s == 'b':
                color = KBD_GRAY
            else:
                color = WHITE
            blank = f'{color}     {RESET}'
            label = f'{color}{BOLD}  {ch}  {RESET}'
            top.append(blank)
            mid.append(label)
            bot.append(blank)
        out.append(offset + ' '.join(top))
        out.append(offset + ' '.join(mid))
        out.append(offset + ' '.join(bot))
        if idx < 2:
            out.append('')
    return out


COPY_HINT = (f'{BOLD}C{RESET}{DIM} copy share  ·  any other key to continue{RESET}')


def render(data, guesses, results, current_guess='', message='', account=None,
           hard_mode=False, extra_lines=None):
    """Render the game UI in a full-terminal centered frame.

    Picks a big (5×3 tile) layout when there is enough vertical and horizontal
    room; falls back to a compact 3×1 layout, and to a non-framed inline mode
    for very small terminals. The cursor is always hidden — typing is shown
    inside the active board row, not on a separate prompt line.
    """
    cols, rows = term_size()
    if cols < 45 or rows < 20:
        return _render_inline(data, guesses, results, current_guess, message,
                              account, hard_mode, extra_lines)

    big = cols >= 65 and rows >= 35
    huge_kbd = cols >= 65 and rows >= 43

    num = data.get('days_since_launch', '?')
    pdate = data.get('print_date', '')
    badge = f' {DIM}· synced{RESET}' if account else f' {DIM}· local{RESET}'
    hard = f' {DIM}· hard{RESET}' if hard_mode else ''

    content = [f'{BOLD}WORDLE{RESET} {DIM}#{num}  {pdate}{RESET}{badge}{hard}', '']
    if big:
        content += big_board_lines(guesses, results, current_guess)
        content.append('')
        if huge_kbd:
            content += huge_keyboard_lines(guesses, results)
        else:
            content += big_keyboard_lines(guesses, results)
    else:
        content += board_lines(guesses, results, current_guess)
        content.append('')
        content += keyboard_lines(guesses, results)
    content.append('')
    content.append(message)
    if extra_lines:
        for line in extra_lines:
            content.append(line)

    inner_h = rows - 2
    top_pad = max(0, (inner_h - len(content)) // 2)

    buf = [CLEAR + HIDE_CURSOR + AUTOWRAP_OFF]
    buf.append(f'\033[1;1H{DIM}┌' + '─' * (cols - 2) + f'┐{RESET}')
    for r in range(2, rows):
        buf.append(f'\033[{r};1H{DIM}│{RESET}\033[{r};{cols}H{DIM}│{RESET}')
    buf.append(f'\033[{rows};1H{DIM}└' + '─' * (cols - 2) + f'┘{RESET}')

    for i, line in enumerate(content):
        r = 2 + top_pad + i
        if r >= rows:
            break
        vis = visible_len(line)
        c = max(2, 1 + (cols - vis) // 2)
        if line:
            buf.append(f'\033[{r};{c}H{line}')

    buf.append('\033[1;1H')
    sys.stdout.write(''.join(buf))
    sys.stdout.flush()


def _render_inline(data, guesses, results, current_guess, message, account,
                   hard_mode, extra_lines):
    """Compact non-framed fallback for terminals smaller than 45×20."""
    sys.stdout.write(CLEAR + AUTOWRAP_ON + HIDE_CURSOR)
    num = data.get('days_since_launch', '?')
    pdate = data.get('print_date', '')
    badge = f' {DIM}· synced{RESET}' if account else f' {DIM}· local{RESET}'
    hard = f' {DIM}· hard{RESET}' if hard_mode else ''
    print(f'  {BOLD}WORDLE{RESET} {DIM}#{num}  {pdate}{RESET}{badge}{hard}')
    print()
    for line in board_lines(guesses, results, current_guess):
        print('  ' + line)
    print()
    for line in keyboard_lines(guesses, results):
        print('  ' + line)
    print()
    print(f'  {message}' if message else '')
    if extra_lines:
        for line in extra_lines:
            print(f'  {line}' if line else '')
    sys.stdout.flush()


# ---------- local stats ----------

def load_stats():
    if STATS_FILE.exists():
        try:
            return json.loads(STATS_FILE.read_text())
        except json.JSONDecodeError:
            pass
    return {
        'played': 0, 'won': 0,
        'streak': 0, 'max_streak': 0,
        'distribution': [0] * 6,
        'last_date': None, 'last_won': False,
    }


def save_stats(stats):
    DATA_DIR.mkdir(exist_ok=True)
    STATS_FILE.write_text(json.dumps(stats))


def update_local_stats(stats, won, attempts, today):
    if stats.get('last_date') == today.isoformat():
        return stats
    stats['played'] += 1
    last = stats.get('last_date')
    if won:
        stats['won'] += 1
        stats['distribution'][attempts - 1] += 1
        cont = False
        if last and stats.get('last_won'):
            try:
                last_d = date.fromisoformat(last)
                cont = (today - last_d).days == 1
            except ValueError:
                pass
        stats['streak'] = stats['streak'] + 1 if cont else 1
        stats['max_streak'] = max(stats['max_streak'], stats['streak'])
    else:
        stats['streak'] = 0
    stats['last_date'] = today.isoformat()
    stats['last_won'] = won
    save_stats(stats)
    return stats


