GREEN     = '\033[48;2;83;141;78;97m'
YELLOW    = '\033[48;2;181;159;59;97m'
GRAY      = '\033[48;2;58;58;60;97m'      # board tiles (dark, matches Wordle UI)
KBD_GRAY  = '\033[48;2;120;124;130;97m'   # keyboard absent — lighter for dark themes
TYPED_BG  = '\033[48;2;90;90;95;97m'      # in-progress (typed but not submitted)
