def _extract_archive_num(args):
    """Pull an `-a N`, `-aN`, `--archive N`, or `--archive=N` flag out of args.
    Returns (num_or_None, remaining_args, error_msg_or_None)."""
    out = []
    i = 0
    num = None
    while i < len(args):
        a = args[i]
        if a in ('-a', '--archive'):
            if i + 1 >= len(args):
                return None, args, f'{a} requires a Wordle number.'
            try:
                num = int(args[i + 1])
            except ValueError:
                return None, args, f'{a} expects a number, got "{args[i + 1]}".'
            i += 2
            continue
        if a.startswith('--archive='):
            try:
                num = int(a.split('=', 1)[1])
            except ValueError:
                return None, args, f'--archive expects a number, got "{a}".'
            i += 1
            continue
        if a.startswith('-a') and len(a) > 2 and a[2:].lstrip('-').isdigit():
            try:
                num = int(a[2:])
            except ValueError:
                return None, args, f'-a expects a number, got "{a}".'
            i += 1
            continue
        out.append(a)
        i += 1
    return num, out, None


def main():
    args = sys.argv[1:]
    hard_mode = '--hard' in args
    zen = '--zen' in args
    args = [a for a in args if a not in ('--hard', '--zen')]

    archive_num, args, err = _extract_archive_num(args)
    if err:
        print(f'  {YELLOW} ! {RESET} {err}', file=sys.stderr)
        return 2

    if archive_num is not None and zen:
        print(f'  {YELLOW} ! {RESET} --zen and --archive can\'t be combined.',
              file=sys.stderr)
        return 2

    if archive_num is not None:
        return archive_play(archive_num, hard_mode=hard_mode)
    if zen:
        return zen_play(hard_mode=hard_mode)
    if not args:
        return main_play(hard_mode=hard_mode)
    cmd = args[0].lower()
    if cmd in ('login', 'signin'):
        return cmd_login()
    if cmd in ('logout', 'signout'):
        return cmd_logout()
    if cmd in ('status', 'whoami'):
        return cmd_status()
    if cmd in ('sync', 'push'):
        return cmd_sync()
    if cmd in ('share', 'copy', 'result'):
        return cmd_share()
    if cmd in ('-h', '--help', 'help'):
        print(f'{BOLD}wordle{RESET}                 Play today\'s NYT Wordle')
        print(f'{BOLD}wordle --hard{RESET}          Hard mode (greens/yellows must be reused)')
        print(f'{BOLD}wordle --zen{RESET}           Unlimited offline play with random words')
        print(f'{BOLD}wordle -a N{RESET}            Play archive Wordle #N (e.g. -a 546)')
        print(f'{DIM}                       --hard combines with --zen or -a.{RESET}')
        print(f'{BOLD}wordle share{RESET}           Copy last game\'s share text to clipboard')
        print(f'{BOLD}wordle login{RESET}           Connect to NYT account (paste NYT-S cookie)')
        print(f'{BOLD}wordle logout{RESET}          Disconnect NYT account')
        print(f'{BOLD}wordle status{RESET}          Show login status')
        print(f'{BOLD}wordle sync{RESET}            Retry pushing the last game to NYT')
        return 0
    print(f'Unknown command: {cmd}. Try `wordle help`.', file=sys.stderr)
    return 2


if __name__ == '__main__':
    sys.exit(main())
