def try_sync(cookie, puzzle_data, guesses, results, won,
             prev_state=None, fallback_user_id=None, hard_mode=False):
    """Attempt to POST to NYT. On 'no such schema version' 400s, retries
    with alternate schema_version values. Returns (ok, error_msg, nyt_view).
    """
    try:
        if prev_state is None:
            try:
                resp = nyt_fetch_state(cookie, puzzle_data['id'])
                states = resp.get('states') or []
                prev_state = next(
                    (s for s in states if s.get('puzzle_id') == puzzle_data['id']),
                    states[0] if states else None,
                )
                if fallback_user_id is None:
                    fallback_user_id = (
                        (prev_state or {}).get('user_id')
                        or (resp.get('player') or {}).get('user_id')
                    )
            except Exception:
                pass
        game_data = build_game_data(prev_state, puzzle_data, guesses, results, won,
                                    hard_mode=hard_mode)
        derived = _extract_schema_version(prev_state)
        # If the targeted GET returned no prev_state for this puzzle, ask
        # NYT for any recent state and crib its schema_version.
        if not derived:
            derived = _discover_schema_version(cookie)
        # Hard-coded fallback matches the value pinned in NYT's wordle JS
        # bundle (schemaVersion = "0.45.0" as of 2026-05). They bump this
        # occasionally; if it stops working, scrape the latest from
        # /games/wordle/index.html or pull from any prev_state.
        candidates = []
        for v in [derived, '0.45.0',
                  'v2', 'v3', 'v4', 'v5', 'v6', 'v7', 'v1',
                  None]:
            if v not in candidates:
                candidates.append(v)
        debug = os.environ.get('WORDLE_DEBUG')
        debug_log = []
        last_err = None
        for sv in candidates:
            body = build_post_body(prev_state, puzzle_data, game_data,
                                   fallback_user_id=fallback_user_id,
                                   schema_override=sv)
            try:
                resp = nyt_post_state(cookie, body, trigger='complete')
                if debug:
                    sys.stderr.write(f'[wordle-debug] sync ok with schema_version={sv!r}\n')
                return True, '', nyt_view_from_response(resp)
            except urllib.error.HTTPError as e:
                err_body = ''
                try:
                    err_body = e.read().decode('utf-8', errors='replace')[:300]
                except Exception:
                    pass
                last_err = (e.code, err_body)
                debug_log.append(f'  schema_version={sv!r} → HTTP {e.code} {err_body}')
                # Only iterate on schema-version errors; bail on other 4xx/5xx.
                if e.code != 400 or 'schema' not in err_body.lower():
                    break
        if debug:
            sys.stderr.write('[wordle-debug] all sync attempts failed:\n')
            sys.stderr.write('\n'.join(debug_log) + '\n')
            try:
                sys.stderr.write('[wordle-debug] prev_state snapshot: '
                                 + json.dumps(prev_state, default=str)[:800] + '\n')
            except Exception:
                pass
        code, err_body = last_err if last_err else (0, '')
        return False, f'Sync failed (HTTP {code}). {err_body}'.strip(), None
    except urllib.error.HTTPError as e:
        try:
            err_body = e.read().decode('utf-8', errors='replace')[:200]
        except Exception:
            err_body = ''
        return False, f'Sync failed (HTTP {e.code}). {err_body}'.strip(), None
    except Exception as e:
        return False, f"Couldn't sync to NYT ({e}).", None


def cmd_sync():
    auth = load_auth()
    cookie = (auth or {}).get('NYT-S')
    if not cookie:
        print(f'  {DIM} · {RESET} Not logged in. Run {BOLD}wordle login{RESET} first.')
        return 1
    pending = load_pending()
    if not pending or pending.get('synced'):
        print(f'  {GREEN} ✓ {RESET} Nothing pending. All caught up.')
