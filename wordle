    'pipes', 'plows', 'pumps', 'puns',  'punks', 'reefs', 'reels', 'rents',
    'rests', 'ribs',  'rinds', 'sails', 'sales', 'salts', 'sands', 'scars',
    'seals', 'seats', 'seeds', 'shells','ships', 'shoes', 'silks', 'silos',
    'skins', 'skirts','slugs', 'snail', 'soaps', 'socks', 'soils', 'sorts',
    'spots', 'spies', 'sticks','stems', 'stops', 'swans', 'tents', 'ticks',
    'tints', 'tires', 'toads', 'tombs', 'traps', 'twigs', 'wages', 'wells',
    'whales','wharves','whips', 'wicks', 'winds', 'wools', 'worms', 'yells',
    'zooms',
]
ZEN_WORDS = sorted({w for w in (ZEN_WORDS + ZEN_PLURALS)
                    if len(w) == 5 and w.isascii() and w.isalpha()})
ZEN_FALLBACK = ZEN_WORDS  # legacy alias


_WORDS_CACHE = None
GUESS_LIST_URL = 'https://raw.githubusercontent.com/tabatkins/wordle-list/main/words'
GUESS_LIST_CACHE = Path.home() / '.cache' / 'wordle-cli' / 'valid_guesses.txt'


def _load_bundled_guesses():
    """Try the on-disk cache, then fetch the canonical Wordle guess list.

    Returns a sorted list of 5-letter ASCII words, or None on failure.
    """
    try:
        if GUESS_LIST_CACHE.is_file():
            words = [
                w for w in GUESS_LIST_CACHE.read_text().split()
                if len(w) == 5 and w.isascii() and w.isalpha()
            ]
            if len(words) >= 5000:
                return sorted(set(words))
    except OSError:
        pass
    try:
        import urllib.request
        with urllib.request.urlopen(GUESS_LIST_URL, timeout=8) as resp:
            text = resp.read().decode('utf-8', 'ignore')
        words = [
            w.lower() for w in text.split()
            if len(w) == 5 and w.isascii() and w.isalpha()
        ]
        if len(words) >= 5000:
            try:
                GUESS_LIST_CACHE.parent.mkdir(parents=True, exist_ok=True)
                GUESS_LIST_CACHE.write_text('\n'.join(sorted(set(words))))
            except OSError:
                pass
            return sorted(set(words))
    except Exception:
        pass
    return None


def _load_system_dict():
    """Fallback: read the system dictionary and synthesize common inflections."""
    for path in ('/usr/share/dict/words', '/usr/share/words'):
        try:
            with open(path) as f:
                raw = [
                    w for w in (line.strip().lower() for line in f)
                    if w.isascii() and w.isalpha() and 3 <= len(w) <= 5
                ]
            fives = {w for w in raw if len(w) == 5}
            # Auto-inflect: most 4-letter words form a valid 5-letter
            # plural / 3rd-person-singular / past tense. The system dict
            # often omits these (e.g. "desks", "tiles"), so synthesize.
            for w in raw:
                if len(w) == 4:
                    fives.add(w + 's')
                    if w.endswith('e'):
                        fives.add(w + 'd')
                    if w.endswith('y') and w[-2] not in 'aeiou':
                        fives.add(w[:-1] + 'ied')
                elif len(w) == 3:
                    if w.endswith(('s', 'x', 'z')) or w.endswith(('ch', 'sh')):
                        fives.add(w + 'es')
            if len(fives) >= 200:
                return sorted(fives)
        except OSError:
            continue
    return None


def load_words():
    """Return a comprehensive list of valid 5-letter guess words.

    Prefers the canonical Wordle guess list (~14.8k words), cached locally.
    Falls back to the system dictionary plus synthesized inflections, then
    finally to the curated ZEN_WORDS pool.
    """
    global _WORDS_CACHE
    if _WORDS_CACHE is not None:
        return _WORDS_CACHE
    words = _load_bundled_guesses() or _load_system_dict()
    if words is None:
        words = list(ZEN_FALLBACK)
    # Always union with the curated zen pool so common solutions are accepted.
    _WORDS_CACHE = sorted(set(words) | set(ZEN_WORDS))
    return _WORDS_CACHE


def load_zen_words():
    return load_words()


def valid_guess(guess, solution, word_set):
    """True if `guess` is the solution or appears in `word_set`."""
    return guess == solution or guess in word_set


def play_round(data, solution, word_set, account, hard_mode=False, intro=''):
    """Run one keystroke-driven round in the framed UI.

    Assumes raw mode is already active and the alt screen has been entered.
    Returns (guesses, results, won) or (None, None, None) if the user aborted.
    """
    guesses, results = [], []
    current = ''
    message = intro
    won = False

    while len(guesses) < 6:
        render(data, guesses, results, current_guess=current, message=message,
               account=account, hard_mode=hard_mode)
        key = read_key()
        if key in ('ctrl-c', 'ctrl-z', 'esc'):
            return None, None, None
        if key == 'enter':
            if len(current) != 5:
                message = f'{YELLOW} ! {RESET} Need 5 letters.'
                continue
            if hard_mode:
                greens, min_letters = hard_mode_constraints(guesses, results)
                violation = hard_mode_violation(current, greens, min_letters)
                if violation:
                    message = f'{YELLOW} ! {RESET} {violation}'
                    continue
            if not valid_guess(current, solution, word_set):
                message = f'{YELLOW} ! {RESET} Not in word list.'
                continue
            r = score(current, solution)
            guesses.append(current)
            results.append(r)
            if current == solution:
                won = True
                break
            current = ''
            message = ''
        elif key == 'backspace':
            if current:
                current = current[:-1]
            message = ''
        elif len(key) == 1 and key.isalpha() and len(current) < 5:
            current += key.lower()
            message = ''
    return guesses, results, won


def final_message(won, guesses, solution):
    if won:
        praise = ['Genius!', 'Magnificent!', 'Impressive!',
                  'Splendid!', 'Great!', 'Phew!'][len(guesses) - 1]
        return f'{BOLD}{GREEN} {praise} {RESET}  Solved in {len(guesses)}/6.'
    return f'{BOLD}{GRAY} The word was {solution.upper()} {RESET}'


def zen_play(hard_mode=False):
    # Solutions come from a curated common-word list so puzzles stay
    # familiar; guesses are validated against the broader system dictionary
    # (plus the solution itself) so the player can still type uncommon words.
    solution_pool = ZEN_WORDS
    word_set = set(load_words()) | set(ZEN_WORDS)
    rng = random.SystemRandom()
    session = 0
    wins = 0

    try:
        enter_fullscreen()
        with RawTerminal():
            while True:
                session += 1
                solution = rng.choice(solution_pool)
                puzzle = {
                    'days_since_launch': f'zen·{session}',
                    'print_date': '',
                    'id': 0,
                    'solution': solution,
                }
                mode_tag = f'{YELLOW} HARD {RESET} ' if hard_mode else ''
                intro = (f'{mode_tag}{DIM}Zen · session {session}. '
                         f'Esc to quit.{RESET}')
                guesses, results, won = play_round(
                    puzzle, solution, word_set, account=False,
                    hard_mode=hard_mode, intro=intro)
                if guesses is None:
                    return 0

                if won:
                    wins += 1
                final_msg = (
                    f'{final_message(won, guesses, solution)}'
                    f'   {DIM}· session {wins}/{session}{RESET}'
                )
                extra = [
                    '',
                    f'{BOLD}Play another?{RESET}  {DIM}[Y / N]{RESET}',
                ]
                render(puzzle, guesses, results, message=final_msg,
                       account=False, hard_mode=hard_mode, extra_lines=extra)

                while True:
                    key = read_key()
                    if key in ('ctrl-c', 'ctrl-z', 'esc') or key.lower() == 'n':
                        return 0
                    if key == 'enter' or key.lower() == 'y':
                        break
    finally:
        exit_fullscreen()


# ---------- main play loop ----------

def main_play(hard_mode=False):
    today = date.today()
    try:
        data = fetch_word(today)
    except Exception as e:
        print(f'Could not fetch today\'s Wordle: {e}', file=sys.stderr)
        return 1
    solution = data['solution'].lower()
    puzzle_id = data['id']

    auth = load_auth()
    cookie = (auth or {}).get('NYT-S')
    nyt_state = None
    nyt_view = None
    nyt_user_id = None
    sync_warning = ''

    # Auto-retry a previously-pending sync (e.g. failed POST from yesterday).
    if cookie:
        pending = load_pending()
        if pending and not pending.get('synced'):
            ok, _, _ = try_sync(cookie, pending['puzzle'],
                                pending['guesses'], pending['results'], pending['won'],
                                hard_mode=pending.get('hard_mode', False))
            if ok:
                mark_synced()

    if cookie:
        try:
            resp = nyt_fetch_state(cookie, puzzle_id)
            states = resp.get('states') or []
            nyt_state = next(
                (s for s in states if s.get('puzzle_id') == puzzle_id),
                states[0] if states else None,
            )
            nyt_user_id = (
                (nyt_state or {}).get('user_id')
                or (resp.get('player') or {}).get('user_id')
            )
            nyt_view = nyt_view_from_response(resp)
        except urllib.error.HTTPError as e:
            sync_warning = f'NYT sync unavailable (HTTP {e.code}). Playing offline.'
            cookie = None
        except Exception as e:
            sync_warning = f'NYT sync unavailable ({e}). Playing offline.'
            cookie = None

    local_stats = load_stats()

    nyt_done_today = bool(
        nyt_state
        and (nyt_state.get('game_data', {}).get('status') in ('WIN', 'FAIL'))
        and nyt_state.get('print_date') == today.isoformat()
    )
    local_done_today = local_stats.get('last_date') == today.isoformat()

    if nyt_done_today or local_done_today:
        sys.stdout.write(CLEAR)
        print(f'  {BOLD}You\'ve already played today\'s Wordle.{RESET}')
        if nyt_view:
            show_stats(nyt_view, source='NYT account')
        else:
            show_stats(local_stats, source='local')
        return 0

    word_set = set(load_words())

    mode_tag = f'{YELLOW} HARD {RESET} ' if hard_mode else ''
    intro = f'{mode_tag}{DIM}Guess the 5-letter word. Esc to quit.{RESET}'
    if sync_warning:
        intro = f'{YELLOW} ! {RESET} {sync_warning}'

    do_copy = False
    try:
        enter_fullscreen()
        with RawTerminal():
            guesses, results, won = play_round(
                data, solution, word_set, account=bool(cookie),
                hard_mode=hard_mode, intro=intro)
            if guesses is None:
                return 0
            final_msg = final_message(won, guesses, solution)
            render(data, guesses, results, message=final_msg,
                   account=bool(cookie), hard_mode=hard_mode,
                   extra_lines=['', COPY_HINT])
            do_copy = (read_key().lower() == 'c')
    finally:
        exit_fullscreen()

    print()
    print(f'  {final_msg}')
    print()
    share = share_text(data, guesses, results, won, hard_mode)
    for line in share.splitlines():
        print('  ' + line)
    print()
    if do_copy:
        if copy_to_clipboard(share):
            print(f'  {GREEN} ✓ {RESET} Copied to clipboard.')
        else:
            print(f'  {YELLOW} ! {RESET} Clipboard tool not found — share text above.')

    local_stats = update_local_stats(local_stats, won, len(guesses), today)
    save_pending(data, guesses, results, won, hard_mode=hard_mode)

    synced = False
    if cookie:
        ok, err, view = try_sync(cookie, data, guesses, results, won,
                                 nyt_state, nyt_user_id, hard_mode=hard_mode)
        if ok:
            synced = True
            nyt_view = view or nyt_view
            mark_synced()
        else:
            print(f'  {YELLOW} ! {RESET} {err} Stats saved locally; '
                  f'run {BOLD}wordle sync{RESET} later to retry.')

    if synced and nyt_view:
        show_stats(nyt_view, source=f'NYT account · synced')
    else:
        show_stats(local_stats, source='local')
    return 0


