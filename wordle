def nyt_request(method, url, cookie, body=None, extra_headers=None):
    headers = {
        'User-Agent': UA,
        'Accept': 'application/json',
        'Cookie': f'NYT-S={cookie}',
        'Referer': 'https://www.nytimes.com/games/wordle/index.html',
        'Origin': 'https://www.nytimes.com',
    }
    if extra_headers:
        headers.update(extra_headers)
    data = None
    if body is not None:
        data = json.dumps(body).encode('utf-8')
        headers['Content-Type'] = 'application/json'
    req = urllib.request.Request(url, data=data, headers=headers, method=method)
    with urllib.request.urlopen(req, timeout=15) as r:
        raw = r.read()
        return json.loads(raw) if raw else {}


def nyt_fetch_state(cookie, puzzle_id):
    url = f'{NYT_GET_URL}?puzzle_ids={puzzle_id}'
    return nyt_request('GET', url, cookie)


def nyt_fetch_latest_states(cookie):
    """Fetch the user's recent wordleV2 states (no puzzle filter).

    Used to discover the current accepted `schema_version` when the
    targeted GET returns no rows (e.g. first time syncing today's puzzle).
    """
    return nyt_request('GET', NYT_GET_URL, cookie)


def _discover_schema_version(cookie):
    """Best-effort: find a working schema_version from any recent state."""
    try:
        resp = nyt_fetch_latest_states(cookie)
    except Exception:
        return None
    for s in (resp.get('states') or []):
        sv = _extract_schema_version(s)
        if sv:
            return sv
    return None


def nyt_post_state(cookie, body, trigger='complete'):
    from datetime import datetime, timezone
    iso = datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%S.') \
        + f'{datetime.now(timezone.utc).microsecond // 1000:03d}Z'
    extra = {
        'x-games-client-time': iso,
        'x-games-aws': 'wrd',
        'x-games-save-trigger': trigger,
    }
    return nyt_request('POST', NYT_POST_URL, cookie, body=body, extra_headers=extra)


def evaluations_from_results(results):
    m = {'g': 'correct', 'y': 'present', 'b': 'absent'}
    return [[m[c] for c in row] for row in results]


def build_game_data(prev_state, puzzle_data, guesses, results, won, hard_mode=False):
    """Build wordleV2 game_data matching NYT's exact schema.

    Only four fields are stored in persist.game per the official client:
    boardState, currentRowIndex, status, hardMode. Stats are computed
    server-side from this state.
    """
    board = list(guesses) + [''] * (6 - len(guesses))
    return {
        'boardState': board,
        'currentRowIndex': len(guesses),
        'status': 'WIN' if won else 'FAIL',
        'hardMode': bool(hard_mode),
    }


def _extract_schema_version(prev_state):
    """Schema version may live at several keys depending on NYT response shape."""
    if not prev_state:
        return None
    for k in ('schema_version', 'schemaVersion', 'schema'):
        v = prev_state.get(k)
        if v not in (None, ''):
            return v
    gd = prev_state.get('game_data') or {}
    for k in ('schema_version', 'schemaVersion'):
        v = gd.get(k)
        if v not in (None, ''):
            return v
    return None


_SCHEMA_SENTINEL = object()


def build_post_body(prev_state, puzzle_data, game_data, fallback_user_id=None,
                    schema_override=_SCHEMA_SENTINEL):
    """Wrap game_data into the envelope the /svc/games/state POST expects.

    `schema_override` controls schema_version: pass `None` to omit the field,
    any other value to use it verbatim, or leave unset to derive from
    prev_state (falling back to 'v2').
    """
    if schema_override is _SCHEMA_SENTINEL:
        schema_version = _extract_schema_version(prev_state) or 'v2'
    else:
        schema_version = schema_override
    user_id = (prev_state or {}).get('user_id') or fallback_user_id
    body = {
        'game': 'wordleV2',
        'game_data': game_data,
        'puzzle_id': str(puzzle_data['id']),
        'print_date': puzzle_data.get('print_date', date.today().isoformat()),
        'timestamp': int(time.time() * 1000),
    }
    if schema_version is not None:
        body['schema_version'] = schema_version
    if user_id is not None:
        body['user_id'] = user_id
    return body


def nyt_view_from_response(resp):
    """Translate NYT GET/POST response into our local stats shape.

    Stats live at player.stats.wordle.totalStats per the official client; the
    legacyStats node is only the migration buffer from before NYT's acquisition.
    """
    player = (resp or {}).get('player') or {}
    wordle = (player.get('stats') or {}).get('wordle') or {}
    s = wordle.get('totalStats') or wordle.get('legacyStats') or {}
    g = s.get('guesses') or {}
    dist = [int(g.get(str(i), 0)) for i in range(1, 7)]
    return {
        'played': int(s.get('gamesPlayed', 0)),
        'won': int(s.get('gamesWon', 0)),
        'streak': int(s.get('currentStreak', 0)),
        'max_streak': int(s.get('maxStreak', 0)),
        'distribution': dist,
        'last_date': s.get('lastWonPrintDate') or None,
        'last_won': True,
        '_fail_count': int(g.get('fail', 0)),
    }


# ---------- display ----------

def show_stats(stats, source=''):
    played = stats['played']
    win_pct = round(100 * stats['won'] / played) if played else 0
    print()
    label = f'STATISTICS {DIM}({source}){RESET}' if source else 'STATISTICS'
    print(f'  {BOLD}{label}{RESET}')
    print(f'  {stats["played"]} played   {win_pct}% wins   '
          f'streak {stats["streak"]}   max {stats["max_streak"]}')
    print()
    print(f'  {BOLD}GUESS DISTRIBUTION{RESET}')
    dist = stats['distribution']
    mx = max(dist) or 1
    for i, count in enumerate(dist, 1):
        bar_len = int(count / mx * 20) if count else 0
        bar = f'{GREEN}{" " * (bar_len + 2)}{RESET}' if bar_len else f'{DIM}··{RESET}'
        print(f'  {i}  {bar} {count}')
    print()


def share_grid(results):
    sym = {'g': '🟩', 'y': '🟨', 'b': '⬛'}
    return '\n'.join(''.join(sym[c] for c in row) for row in results)


def share_text(puzzle_data, guesses, results, won, hard_mode):
    """Build the official Wordle share format, e.g.:
        Wordle 1,781 4/6*

        ⬛🟨🟨⬛⬛
        ...
    """
    num = puzzle_data.get('days_since_launch', 0)
    score = f'{len(guesses)}/6' if won else 'X/6'
    star = '*' if hard_mode else ''
    header = f'Wordle {num:,} {score}{star}'
    return f'{header}\n\n{share_grid(results)}'


def copy_to_clipboard(text):
    """Best-effort clipboard copy. Returns True on success."""
    if sys.platform == 'darwin' and shutil.which('pbcopy'):
        cmd = ['pbcopy']
    elif shutil.which('wl-copy'):
        cmd = ['wl-copy']
    elif shutil.which('xclip'):
        cmd = ['xclip', '-selection', 'clipboard']
    elif shutil.which('xsel'):
        cmd = ['xsel', '--clipboard', '--input']
    else:
        return False
    try:
        p = subprocess.run(cmd, input=text.encode('utf-8'), check=True, timeout=3)
        return p.returncode == 0
    except (subprocess.SubprocessError, OSError):
        return False


# ---------- hard mode ----------

def hard_mode_constraints(guesses, results):
    """Derive hard-mode constraints from prior guesses.

    Returns (greens, min_letters):
      greens: dict {pos: letter} — letters revealed at fixed positions
      min_letters: Counter {letter: min_count_required}
    """
    greens = {}
    min_letters = Counter()
    for guess, res in zip(guesses, results):
        seen = Counter()
        for i, (ch, r) in enumerate(zip(guess, res)):
            if r == 'g':
                greens[i] = ch
                seen[ch] += 1
            elif r == 'y':
                seen[ch] += 1
        for ch, n in seen.items():
            if n > min_letters[ch]:
                min_letters[ch] = n
    return greens, min_letters


def hard_mode_violation(guess, greens, min_letters):
    """Return a human message if guess violates hard mode, else None."""
    for pos, letter in greens.items():
        if guess[pos] != letter:
            return f'{(pos + 1)}{_ord_suffix(pos + 1)} letter must be {letter.upper()}.'
    have = Counter(guess)
    for letter, n in min_letters.items():
        if have[letter] < n:
            req = 'once' if n == 1 else f'{n} times'
            return f'Guess must contain {letter.upper()} ({req}).'
    return None


def _ord_suffix(n):
    return {1: 'st', 2: 'nd', 3: 'rd'}.get(n if n < 20 else n % 10, 'th')


