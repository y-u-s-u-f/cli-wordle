    puzzle = pending['puzzle']
    print(f'  Pushing Wordle #{puzzle.get("days_since_launch", "?")} '
          f'({puzzle.get("print_date")}) to NYT…')
    ok, err, view = try_sync(cookie, puzzle,
                             pending['guesses'], pending['results'], pending['won'],
                             hard_mode=pending.get('hard_mode', False))
    if ok:
        mark_synced()
        print(f'  {GREEN} ✓ {RESET} Synced.')
        if view:
            show_stats(view, source='NYT account')
        return 0
    print(f'  {YELLOW} ! {RESET} {err}')
    return 1


